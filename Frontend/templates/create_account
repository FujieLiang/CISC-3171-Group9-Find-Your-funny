<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <header>
        <div class = "logo"> FindYourFunny</div>
        <nav>
            <ul class="nav-links">
                <li><a href="#" class = "active">Events</a></li>
