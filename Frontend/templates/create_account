            </ul>
        </nav>
    </header>

    <h2>
        Create Account
    </h2>
    <form id="signupForm" class="form-card">
        <input name="username" placeholder="Username">
        <input name="password" placeholder="Password">
        <input name="email" placeholder="Email Address">
        <input name="firstName" placeholder="Last Name">
        <input name="lastName" placeholder="First Name">
        <input name="streetAddress" placeholder="Street Address">
        <input name="city" placeholder="City">
        <input name="state" placeholder="State">
        <input name="zipCode" placeholder="Zip Code">
        <input name="country" placeholder="Country (i.e US)">
        <button type="submit">Create Account</button>
    </form>



    
</body>
